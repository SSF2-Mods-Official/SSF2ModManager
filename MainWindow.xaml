<Window x:Class="SSF2ModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:SSF2ModManager.Converters"
        xmlns:local="clr-namespace:SSF2ModManager"
        xmlns:views="clr-namespace:SSF2ModManager.Views"
        mc:Ignorable="d"
        Title="{local:Loc AppTitle}" Height="700" Width="1050" MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/SSF2M.png"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <converters:BoolToEnabledTextConverter x:Key="BoolToEnabledText"/>
        <converters:BoolToToggleTextConverter x:Key="BoolToToggleText"/>
        <converters:BoolToColorConverter x:Key="BoolToColor"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacity"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

    <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="{DynamicResource SidebarBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <Image Source="pack://application:,,,/SSF2M.png" Width="20" Height="20" Margin="4,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{local:Loc AppTitle}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
            </StackPanel>

        <!-- Full-window loading overlay (hidden by default) -->
        <Grid x:Name="OverlayLoading" Grid.RowSpan="2" Visibility="Collapsed" Background="#80000000" IsHitTestVisible="True">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="OverlaySpinner" Width="64" Height="64" Stroke="{DynamicResource AccentBrush}" StrokeThickness="6"
                             StrokeDashArray="2 2" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <TextBlock x:Name="TxtOverlayMessage" Text="Checking for updates..." Margin="0,12,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

                                     <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                <Button x:Name="BtnDiscord" Content="{local:Loc DiscordButton}" Click="BtnDiscord_Click" Cursor="Hand"
                        FontSize="11" Padding="10,4" Margin="0,0,4,0" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FF4752C4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnFeedback" Content="✉ Feedback" Click="BtnFeedback_Click" Cursor="Hand"
                        FontSize="11" Padding="10,4" Margin="0,0,4,0" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FF246FE6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnSupport" Content="{local:Loc SupportButton}" Click="BtnSupport_Click" Cursor="Hand"
                        FontSize="11" Padding="10,4" Margin="0,0,4,0" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FFE04E4B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="BtnMinimize" Content="{local:Loc MinimizeButton}" Click="BtnMinimize_Click" FontSize="13" Width="46" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnMaximize" Content="{local:Loc MaximizeButton}" Click="BtnMaximize_Click" FontSize="13" Width="46" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnClose" Content="{local:Loc CloseButton}" Click="BtnClose_Click" FontSize="13" Width="46" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FFE53935"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="1" Background="#20FFFFFF" Margin="16,14,16,10"/>

                    <StackPanel DockPanel.Dock="Bottom" Margin="20,10">
                        <TextBlock Text="v1.1.0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="GameBanana API" FontSize="10" Foreground="#50FFFFFF"/>
                    </StackPanel>

                        <StackPanel>
                        <Button x:Name="BtnBrowse" Content="{local:Loc BrowseSidebar}" 
                            Style="{StaticResource SidebarButtonActive}" Click="BtnBrowse_Click"/>
                        <Button x:Name="BtnInstalled" Content="{local:Loc InstalledSidebar}" 
                            Style="{StaticResource SidebarButton}" Click="BtnInstalled_Click"/>
                        <Button x:Name="BtnBuilds" Content="{local:Loc BuildsSidebar}" 
                            Style="{StaticResource SidebarButton}" Click="BtnBuilds_Click"/>
                        <Button x:Name="BtnCostumes" Content="{local:Loc CostumesSidebar}" 
                            Style="{StaticResource SidebarButton}" Click="BtnCostumes_Click"/>
                        <Button x:Name="BtnEvents" Content="{local:Loc EventsSidebar}" 
                            Style="{StaticResource SidebarButton}" Click="BtnEvents_Click"/>
                        <Button x:Name="BtnNews" Content="📰  News" 
                            Style="{StaticResource SidebarButton}" Click="BtnNews_Click"/>
                        <Button x:Name="BtnGettingStarted" Content="📘  Getting Started" 
                            Style="{StaticResource SidebarButton}" Click="BtnGettingStarted_Click"/>
                        <Button x:Name="BtnSettings" Content="{local:Loc SettingsSidebar}" 
                            Style="{StaticResource SidebarButton}" Click="BtnSettings_Click"/>
                        <Border Height="1" Background="#20FFFFFF" Margin="16,8"/>
                        <Button x:Name="BtnLog" Content="{local:Loc DebugLogSidebar}" 
                            Style="{StaticResource SidebarButton}" Click="BtnLog_Click"/>
                        </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1">

            <!-- ═══ Browse Mods Page ═══ -->
            <Grid x:Name="PageBrowse" Margin="24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{local:Loc BrowseMods}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <TextBox x:Name="TxtSearch" Style="{StaticResource ModernTextBox}"
                                 Text="" Padding="10,8,30,8" KeyDown="TxtSearch_KeyDown"
                                 TextChanged="TxtSearch_TextChanged">
                            <TextBox.ToolTip>Search for SSF2 mods on GameBanana</TextBox.ToolTip>
                        </TextBox>
                        <Button x:Name="BtnClearSearch" Content="{local:Loc ClearSearch}" Click="BtnClearSearch_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,6,0" Padding="4,2" FontSize="11" Cursor="Hand"
                            Foreground="#80FFFFFF" Background="Transparent" BorderThickness="0"
                            Visibility="Collapsed"/>
                    </Grid>

                    <ComboBox x:Name="CmbSort" Grid.Column="1" Width="140" Margin="0,0,8,0"
                              Style="{StaticResource ModernComboBox}" SelectionChanged="CmbSort_Changed">
                        <ComboBoxItem Content="{local:Loc SortDefault}" IsSelected="True"/>
                        <ComboBoxItem Content="{local:Loc SortNewest}"/>
                        <ComboBoxItem Content="{local:Loc SortUpdated}"/>
                        <ComboBoxItem Content="{local:Loc SortMostLiked}"/>
                        <ComboBoxItem Content="{local:Loc SortMostDownloaded}"/>
                    </ComboBox>

                        <Button x:Name="BtnSearch" Grid.Column="2" Content="{local:Loc SearchButton}" 
                            Style="{StaticResource ModernButton}" Click="BtnSearch_Click" Margin="0,0,8,0"/>

                        <Button x:Name="BtnInstallLocal" Grid.Column="3" Content="{local:Loc InstallLocalButton}" 
                            Style="{StaticResource ModernButton}" Click="BtnInstallLocal_Click"/>
                </Grid>

                <ScrollViewer x:Name="BrowseScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="TxtLoading" Text="{local:Loc LoadingMods}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,40" Visibility="Collapsed"/>

                        <TextBlock x:Name="TxtNoResults" Text="{local:Loc NoModsFound}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,40" Visibility="Collapsed"/>

                        <ItemsControl x:Name="ModBrowserList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                                            Padding="16" Margin="0,0,0,10"
                                            Tag="{Binding}" MouseEnter="BrowseCard_MouseEnter">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" CornerRadius="6" Width="100" Height="75"
                                                    Background="#20FFFFFF" ClipToBounds="True">
                                                <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0">
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" 
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="12" Margin="0,2,0,4">
                                                    <Hyperlink Foreground="{DynamicResource AccentBrush}" 
                                                               TextDecorations="None" Cursor="Hand"
                                                               Tag="{Binding}" Click="BtnSearchByCreator_Click">
                                                        <Run Text="{Binding AuthorName, Mode=OneWay}"/>
                                                    </Hyperlink>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" FontSize="12" MaxHeight="34"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" 
                                                           TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="{Binding StatsText}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock FontSize="11" Margin="12,0,0,0">
                                                            <Hyperlink Foreground="{DynamicResource PrimaryBrush}" 
                                                                   TextDecorations="None" Cursor="Hand"
                                                                   Tag="{Binding}" Click="BtnSearchByCategory_Click">
                                                            <Run Text="{Binding CategoryName, Mode=OneWay}"/>
                                                        </Hyperlink>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                                                        <Button Content="{local:Loc VideoButton}" Style="{StaticResource ModernButton}"
                                                            Tag="{Binding}" Click="BtnCardVideo_Click" Padding="10,6"
                                                            Margin="0,0,6,0" FontSize="11"
                                                            Visibility="{Binding HasVideo, Converter={StaticResource BoolToVisibility}}"/>
                                                        <Button Content="{local:Loc InstallButton}" Style="{StaticResource AccentButton}"
                                                            Tag="{Binding}" Click="BtnInstallMod_Click"
                                                            Visibility="{Binding IsNotInstalled, Converter={StaticResource BoolToVisibility}}"/>
                                                        <Button Content="{Binding ToggleTextLocalized}" Style="{StaticResource ModernButton}"
                                                            Tag="{Binding}" Click="BtnBrowseToggleMod_Click"
                                                            Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <Button Content="{local:Loc ViewPageButton}" Style="{StaticResource ModernButton}"
                                                    Tag="{Binding}" Click="BtnViewOnGB_Click" Padding="16,6"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="3" Margin="0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="BtnPrevPage" Content="{local:Loc PrevPageButton}" Style="{StaticResource ModernButton}" 
                                Click="BtnPrevPage_Click" Margin="0,0,8,0" IsEnabled="False"/>
                        <TextBlock x:Name="TxtPageInfo" Text="Page 1" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="8,0"/>
                            <Button x:Name="BtnNextPage" Content="{local:Loc NextPageButton}" Style="{StaticResource ModernButton}" 
                                Click="BtnNextPage_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Grid Grid.Column="2" x:Name="PlayButtonPanel" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnPlay" Grid.Column="0" Content="{local:Loc PlayButton}" 
                                Click="BtnPlay_Click" FontSize="13" FontWeight="SemiBold"
                                Padding="16,7,12,7" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF4CAF50"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="6,0,0,6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF66BB6A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#FF388E3C"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="BtnPlayDropdown" Grid.Column="1" Content="{local:Loc PlayDropdown}" 
                            Click="BtnPlayDropdown_Click" FontSize="12" FontWeight="Bold"
                                Padding="6,7" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF388E3C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="0,6,6,0" Padding="{TemplateBinding Padding}"
                                                        BorderBrush="#30000000" BorderThickness="1,0,0,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF4CAF50"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#FF2E7D32"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="PlayVersionMenu"/>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Grid>

                <!-- Mod Preview Panel -->
                <Border Grid.Row="4" x:Name="PreviewPanel" Background="{DynamicResource CardBrush}" 
                    CornerRadius="8" Padding="16" Margin="0,8,0,0" MinHeight="80"
                        MaxHeight="160" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="TxtPreviewTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"
                                   TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtPreviewDescription" FontSize="12" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Installed Mods Page ═══ -->
            <Grid x:Name="PageInstalled" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{local:Loc InstalledMods}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtModCount" Grid.Row="1" Text="{local:Loc InstalledMods}" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                <!-- Filters -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Filter:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbFilterBuild" Width="160" Style="{StaticResource ModernComboBox}"
                              SelectionChanged="CmbFilter_Changed" Margin="0,0,8,0"/>
                    <!-- Version filter removed per request -->
                    <ComboBox x:Name="CmbFilterCategory" Width="140" Style="{StaticResource ModernComboBox}"
                              SelectionChanged="CmbFilter_Changed" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbFilterCreator" Width="150" Style="{StaticResource ModernComboBox}"
                              SelectionChanged="CmbFilter_Changed"/>
                            <Button x:Name="BtnCheckAllInstalledUpdates" Content="Check for Updates" Style="{StaticResource ModernButton}"
                            Click="BtnCheckAllInstalledUpdates_Click" Margin="12,0,0,0" Padding="10,6"/>
                </StackPanel>

                <ScrollViewer x:Name="InstalledScrollViewer" Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="TxtNoMods" Text="{local:Loc NoModsInstalled}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,40" Visibility="Collapsed"/>

                        <ItemsControl x:Name="InstalledModsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                                            Padding="16" Margin="0,0,0,10"
                                            Opacity="{Binding Enabled, Converter={StaticResource BoolToOpacity}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding Enabled, Converter={StaticResource BoolToColor}}"/>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Author}" FontSize="12"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    <TextBlock Text=" • " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                                    <TextBlock Text="{Binding Category}" FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text=" • " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                                    <TextBlock Text="{Binding BuildDisplayName}" FontSize="12"
                                                                   Foreground="{DynamicResource PrimaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Enabled, Converter={StaticResource BoolToEnabledText}}" 
                                                           FontSize="11" Margin="0,4,0,0"
                                                           Foreground="{Binding Enabled, Converter={StaticResource BoolToColor}}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- per-item update button removed; use global Check updates button above -->
                                                <Button Content="{local:Loc InstallAnyway}" Style="{StaticResource AccentButton}"
                                                    Tag="{Binding}" Click="BtnInstallAnyway_Click" Margin="0,0,6,0"
                                                    Padding="10,6" FontSize="11"
                                                    Visibility="{Binding IsGameFiles, Converter={StaticResource BoolToVisibility}}"/>
                                                <Button Content="{Binding Enabled, Converter={StaticResource BoolToToggleText}}" 
                                                        Style="{StaticResource ModernButton}"
                                                        Tag="{Binding}" Click="BtnToggleMod_Click" Margin="0,0,6,0"/>
                                                <Button Content="{local:Loc SettingsButton}" Style="{StaticResource ModernButton}"
                                                    Tag="{Binding}" Click="BtnInstalledModSettings_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ Settings Page ═══ -->
            <Grid x:Name="PageSettings" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                      <TextBlock Grid.Row="0" Text="{local:Loc Settings}" FontSize="22" FontWeight="SemiBold"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Info.json tool moved to Getting Started (Resources) -->
                        <!-- SSF2 Versions -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc InstalledBuilds}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{local:Loc AddVersionHelp}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                                <ItemsControl x:Name="VersionsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#15FFFFFF" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="13"
                                                                               FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                                                               MinWidth="100" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding FolderPath}" FontSize="12" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis" Margin="12,0"
                                                               VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" Content="{local:Loc RemoveButton}" Style="{StaticResource DangerButton}"
                                                            Padding="8,4" Tag="{Binding}" Click="BtnRemoveVersion_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock x:Name="TxtNoVersions" 
                                           Text="{local:Loc NoVersionsConfigured}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                           Margin="0,4,0,8" FontStyle="Italic"/>

                                <Button Content="{local:Loc AddVersionButton}" Style="{StaticResource AccentButton}" 
                                    Click="BtnAddVersion_Click" HorizontalAlignment="Left"
                                    Margin="0,4,0,0" Padding="16,8"/>

                                <!-- Language Selection -->
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{local:Loc Language}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbLanguage" Width="160" SelectionChanged="CmbLanguage_SelectionChanged" Style="{StaticResource DarkComboBox}">
                                        <ComboBoxItem Content="{local:Loc LanguageEnglish}" Tag="en"/>
                                        <ComboBoxItem Content="{local:Loc LanguageSpanish}" Tag="es"/>
                                    </ComboBox>
                                </StackPanel>
                                <!-- Theme Selection -->
                                <StackPanel Orientation="Vertical" Margin="0,12,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Theme" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CmbTheme" Width="220" SelectionChanged="CmbTheme_SelectionChanged" Style="{StaticResource DarkComboBox}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TxtThemeDebug" Text="" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- How Mods Work -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc HowModsWork}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" LineHeight="22">
                                    <Run Text="{local:Loc HowMods_Step1}"/>
                                    <LineBreak/>
                                    <Run Text="{local:Loc HowMods_Step2}"/>
                                    <LineBreak/>
                                    <Run Text="{local:Loc HowMods_Step3}"/>
                                    <LineBreak/>
                                    <Run Text="{local:Loc HowMods_Step4}"/>
                                    <LineBreak/>
                                    <Run Text="{local:Loc HowMods_Step5}"/>
                                    <LineBreak/>
                                    <Run Text="{local:Loc HowMods_Step6}"/>
                                    <LineBreak/>
                                    <Run Text="{local:Loc HowMods_Step7}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- About -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc About}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{local:Loc AppTitle}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="Created by MasterWex" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                                <TextBlock Text="Spanish Translation by Little Fabi" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                                <TextBlock Text="GameBanana Mod Manager for Super Smash Flash 2" 
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                                <TextBlock Text="Powered by the GameBanana API" 
                                           Foreground="#50FFFFFF" FontSize="11" Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="Check for Updates" Style="{StaticResource ModernButton}"
                                            Click="BtnCheckProgramUpdate_Click" Padding="10,6"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ News Page ═══ -->
            <views:NewsPage x:Name="PageNews" Visibility="Collapsed" Margin="24,20" />

            <!-- ═══ Debug Log Page ═══ -->
            <Grid x:Name="PageLog" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{local:Loc DebugLog}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScrollViewer">
                        <TextBox x:Name="TxtDebugLog" IsReadOnly="True" TextWrapping="Wrap"
                                 Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                                 BorderThickness="0" FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Disabled"/>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="{local:Loc Refresh}" Style="{StaticResource ModernButton}" 
                            Click="BtnRefreshLog_Click" Margin="0,0,8,0"/>
                    <Button Content="{local:Loc ClearLog}" Style="{StaticResource DangerButton}" 
                            Click="BtnClearLog_Click"/>
                </StackPanel>
            </Grid>

            <!-- ═══ Installed Builds Page ═══ -->
            <Grid x:Name="PageBuilds" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{local:Loc InstalledBuilds}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtBuildCount" Grid.Row="1" Text="{local:Loc InstalledBuilds}" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="TxtNoBuilds" Text="{local:Loc NoBuildsConfigured}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,40" Visibility="Collapsed"/>

                        <ItemsControl x:Name="BuildsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                                            Padding="20" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="17" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                                <TextBlock Text="{Binding FolderPath}" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,8"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding ModCountText}" FontSize="13"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                </StackPanel>

                                                <ItemsControl ItemsSource="{Binding CategoryBreakdown}" Margin="4,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding ExeStatusText}" FontSize="11" Margin="0,6,0,0"
                                                           Foreground="{Binding ExeStatusColor}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Button Content="{local:Loc PlaySmall}" Style="{StaticResource AccentButton}"
                                                    Tag="{Binding}" Click="BtnPlayBuild_Click" 
                                                    Padding="20,8" Margin="0,0,0,6"/>
                                                <Button Content="{local:Loc SettingsButton}" Style="{StaticResource ModernButton}"
                                                    Tag="{Binding}" Click="BtnBuildSettings_Click"
                                                    Padding="14,7"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Left">
                            <Button Content="{local:Loc AddVersionButton}" Style="{StaticResource AccentButton}"
                                Click="BtnAddVersion_Click" Padding="16,8"/>
                            <Button Content="Download SSF2" Style="{StaticResource ModernButton}"
                                Tag="https://www.supersmashflash.com/play/ssf2/downloads/archives/"
                                Click="BtnResourceLink_Click" Margin="8,0,0,0" Padding="12,8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ Manage Costumes Page ═══ -->
            <Grid x:Name="PageCostumes" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{local:Loc ManageCostumes}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="24" VerticalAlignment="Top">
                    <TextBlock Text="Costume management coming soon. This will let you manage alternate character costumes for SSF2."
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- ═══ Manage Events Page ═══ -->
            <Grid x:Name="PageEvents" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{local:Loc ManageEvents}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="24" VerticalAlignment="Top">
                    <TextBlock Text="Event management coming soon. This will let you create and manage SSF2 events."
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- ═══ Mod SSF2 Page ═══ -->
            <Grid x:Name="PageModSSF2" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{local:Loc ModSSF2}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="24" VerticalAlignment="Top">
                    <TextBlock Text="SSF2 modding tools coming soon. This will provide advanced tools for modding SSF2 directly." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- ═══ Getting Started Page (combined) ═══ -->
            <Grid x:Name="PageGettingStarted" Margin="24,20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Getting Started" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Tutorial Card -->
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="📘 Tutorial" FontSize="18" FontWeight="SemiBold"
                                               Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="New to SSF2 Mod Manager? Take a quick tutorial to learn how to add versions, browse mods, and get started modding!"
                                               FontSize="13" Foreground="#E0FFFFFF" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="BtnTutorial" Content="Start Tutorial" 
                                        Style="{StaticResource ModernButton}"
                                        Click="BtnTutorial_Click" Padding="16,8" VerticalAlignment="Center"
                                        Background="White" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="SSF2 modding tools" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="Create info.json (optional)" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="Creator:" Width="80" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBox x:Name="TxtInfoCreator" Width="260"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="SSF2 Version:" Width="80" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <ComboBox x:Name="CmbInfoSSF2Version" Width="260" Style="{StaticResource ModernComboBox}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="Mod Type:" Width="80" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <ComboBox x:Name="CmbInfoModType" Width="260" Style="{StaticResource ModernComboBox}">
                                                <ComboBoxItem>Character</ComboBoxItem>
                                                <ComboBoxItem>Stage</ComboBoxItem>
                                                <ComboBoxItem>Texture</ComboBoxItem>
                                                <ComboBoxItem>Music</ComboBoxItem>
                                                <ComboBoxItem>Script</ComboBoxItem>
                                                <ComboBoxItem>Mod Pack</ComboBoxItem>
                                                <ComboBoxItem>Other</ComboBoxItem>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Left">
                                            <Button x:Name="BtnSaveInfoJson" Content="Save As" Style="{StaticResource AccentButton}" Click="BtnSaveInfoJson_Click" Padding="12,6"/>
                                            <Button x:Name="BtnFillDefaults" Content="Fill Defaults" Margin="8,0,0,0" Padding="12,6" Click="BtnFillDefaults_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Resources Section -->
                        <!-- Wiki -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="📖 SSF2 Modding Wiki" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Official wiki for SSF2 modding, with guides, tutorials, and documentation for modders of all skill levels."
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Open" Style="{StaticResource AccentButton}"
                                    Tag="https://ssf2mods.miraheze.org/wiki/Main_Page"
                                    Click="BtnResourceLink_Click" Padding="16,8" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Sandbox -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🎨 Sandbox" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Modpack from SSF2 1.3 with large collection of mods and easy installation."
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Open" Style="{StaticResource AccentButton}"
                                    Tag="https://color-vault.github.io/Color-Vault/downloads.html"
                                    Click="BtnResourceLink_Click" Padding="16,8" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="⚡ Reflash 2" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="An open-source tool for reflashing and modifying SSF2 builds."
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Open" Style="{StaticResource AccentButton}"
                                    Tag="https://github.com/SSF2-Mods-Official/reflash2"
                                    Click="BtnResourceLink_Click" Padding="16,8" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="📦 SSF2 Modding Vault" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="A curated collection of SSF2 modding resources, tools, and documentation."
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Open" Style="{StaticResource AccentButton}"
                                    Tag="https://github.com/SSF2-Mods-Official/ssf2-modding-vault"
                                    Click="BtnResourceLink_Click" Padding="16,8" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Download overlay -->
            <Border x:Name="DownloadOverlay" Background="#CC000000" Visibility="Collapsed">
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" 
                        Padding="32" VerticalAlignment="Center" HorizontalAlignment="Center"
                        MinWidth="350">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtDownloadStatus" Text="Downloading mod..." FontSize="16" 
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <ProgressBar x:Name="DownloadProgress" Width="280" Height="6" 
                                     Minimum="0" Maximum="100" Value="0"
                                     Foreground="{DynamicResource PrimaryBrush}" Background="#30FFFFFF"/>
                        <TextBlock x:Name="TxtDownloadPercent" Text="0%" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>
