<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- High contrast -->
  <Color x:Key="BackgroundColor">#FF000000</Color>
  <Color x:Key="CardColor">#FF000000</Color>
  <Color x:Key="TextPrimaryColor">#FFFFFFFF</Color>
  <Color x:Key="TextSecondaryColor">#FFFFFFFF</Color>
  <Color x:Key="AccentColor">#FFFF00FF</Color>

  <!-- Sidebar and surface keys so app areas update correctly -->
  <Color x:Key="SidebarColor">#FF000000</Color>
  <Color x:Key="SurfaceColor">#FF000000</Color>

  <!-- Selection (used for highlights) -->
  <Color x:Key="SelectionBackgroundColor">#FFFF00FF</Color>
  <Color x:Key="SelectionForegroundColor">#FFFFFFFF</Color>

  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
  <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{StaticResource SelectionBackgroundColor}"/>
  <SolidColorBrush x:Key="SelectionForegroundBrush" Color="{StaticResource SelectionForegroundColor}"/>
</ResourceDictionary>