<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Forest green -->
  <Color x:Key="BackgroundColor">#FF0B2D13</Color>
  <Color x:Key="CardColor">#FF0F3B1C</Color>
  <Color x:Key="TextPrimaryColor">#FFEFF8F1</Color>
  <Color x:Key="TextSecondaryColor">#FF9BC5A6</Color>
  <Color x:Key="AccentColor">#FF4CAF50</Color>

  <!-- Sidebar and surface keys so app areas update correctly -->
  <Color x:Key="SidebarColor">#FF0B2D13</Color>
  <Color x:Key="SurfaceColor">#FF0F3B1C</Color>

  <!-- Selection (used for highlights) -->
  <Color x:Key="SelectionBackgroundColor">#FF4CAF50</Color>
  <Color x:Key="SelectionForegroundColor">#FFEFF8F1</Color>

  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
  <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{StaticResource SelectionBackgroundColor}"/>
  <SolidColorBrush x:Key="SelectionForegroundBrush" Color="{StaticResource SelectionForegroundColor}"/>
</ResourceDictionary>