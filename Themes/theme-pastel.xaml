<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Soft Pastel -->
  <Color x:Key="BackgroundColor">#FFFFFBFE</Color>
  <Color x:Key="CardColor">#FFFFF7FB</Color>
  <Color x:Key="TextPrimaryColor">#FF333333</Color>
  <Color x:Key="TextSecondaryColor">#FF666666</Color>
  <Color x:Key="AccentColor">#FFEF9A9A</Color>

  <!-- Sidebar and surface keys so app areas update correctly -->
  <Color x:Key="SidebarColor">#FFFFF7FB</Color>
  <Color x:Key="SurfaceColor">#FFFFF7FB</Color>

  <!-- Selection (used for highlights) -->
  <Color x:Key="SelectionBackgroundColor">#FFEF9A9A</Color>
  <Color x:Key="SelectionForegroundColor">#FF333333</Color>

  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
  <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{StaticResource SelectionBackgroundColor}"/>
  <SolidColorBrush x:Key="SelectionForegroundBrush" Color="{StaticResource SelectionForegroundColor}"/>
</ResourceDictionary>