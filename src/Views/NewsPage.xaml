<UserControl x:Class="SSF2ModManager.Views.NewsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock x:Name="TxtNewsStatus" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                <Button x:Name="BtnMarkAllRead" Content="Mark all read" Click="BtnMarkAllRead_Click"
                        Style="{StaticResource ModernButton}" Margin="0,0,8,0"/>
                <Button x:Name="BtnRefreshNews" Content="Refresh" Click="BtnRefreshNews_Click" Style="{StaticResource ModernButton}"/>
            </StackPanel>
            <ListBox x:Name="LstArticles" SelectionChanged="LstArticles_SelectionChanged"
                     Background="{DynamicResource CardBrush}" BorderThickness="0"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,0,0,8" CornerRadius="6" Background="{DynamicResource CardBrush}">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Date, StringFormat=d}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding Excerpt}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="48"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="12">
            <FlowDocumentScrollViewer x:Name="DocViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" />
        </Border>
    </Grid>
</UserControl>
